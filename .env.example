# Application environment: development, test, production
APP_ENV=development

# HTTP port used by the combined API and web server
PORT=8080

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# Persistence backend: postgres for production, file for local shared dev, memory for tests
DATABASE_DRIVER=file

# PostgreSQL connection string. Required when DATABASE_DRIVER=postgres.
DATABASE_URL=postgres://evolution_rpg:change-me@localhost:5432/evolution_rpg

# Logical ledger key stored in the database. Change only if hosting multiple ledgers.
APP_STATE_KEY=main

# File-backed state path for DATABASE_DRIVER=file. Do not use for multi-container production.
STATE_FILE=.data/state.json

# Maximum accepted JSON API body size in bytes.
MAX_BODY_BYTES=5242880

# Optional PostgreSQL pool tuning.
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000
