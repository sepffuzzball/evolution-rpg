{
  "name": "evolution-rpg",
  "version": "0.1.0",
  "private": true,
  "description": "Shared web character creator and sheet manager for Evolution RPG.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --pretty",
    "test": "node --test server/*.test.js"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "typescript": "5.9.3",
    "vite": "5.4.21"
  }
}
